---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { cldUrl, cldVideoUrl } from '../lib/cloudinary.js';

// `scrollSeq` (set by the home page) means the GLOBAL scroll-scrub backdrop
// (ScrollSeq) is mounted on this page — the page ends parked on the green
// valley, so the closing GTM band folds onto that green frame (no own
// landscape). On every OTHER page (no backdrop) the GTM band keeps its own
// self-contained landscape video + topographic fallback so it still reads.
const { content, page, ogImage, scrollSeq = false } = Astro.props;
const { meta, nap, design, cloudinary, analytics } = content;
const ph = analytics?.posthog;
const phOn = Boolean(ph?.enabled && ph?.apiKey);

// Canonical = apex site + this page's path (which already includes the base/slug).
const canonical = new URL(Astro.url.pathname, Astro.site ?? meta.siteUrl).href;
const seo = page.seo ?? {};

// Design tokens → CSS variables. Single source of truth is content.json.design.
const c = design.colors;
const f = design.fonts;
const s = design.scale;
const m = design.motion ?? {};
const tokenCss = `:root{
  --ac-primary:${c.primary};--ac-primary-contrast:${c.primaryContrast};
  --ac-accent:${c.accent};--ac-accent-contrast:${c.accentContrast};
  --ac-bg:${c.bg};--ac-bg-muted:${c.bgMuted};--ac-surface:${c.surface};
  --ac-text:${c.text};--ac-text-muted:${c.textMuted};--ac-border:${c.border};
  --ac-font-heading:${f.heading};--ac-font-body:${f.body};
  --ac-radius:${s.radius};--ac-shadow:${s.shadow};--ac-max:${s.maxWidth};
  --ac-motion-duration:${m.durationMs ?? 500}ms;--ac-motion-easing:${m.easing ?? 'ease'};
}`;

// LocalBusiness/LegalService JSON-LD from the NAP — only real, supplied fields.
// Address sub-fields are included only when present, and the address object is
// omitted entirely for a virtual business with no physical location (so the
// schema never carries empty strings).
const addr = Object.fromEntries(
  Object.entries({
    streetAddress: nap.streetAddress,
    addressLocality: nap.addressLocality,
    addressRegion: nap.addressRegion,
    postalCode: nap.postalCode,
    addressCountry: nap.addressCountry,
  }).filter(([, v]) => v),
);
const schema = {
  '@context': 'https://schema.org',
  '@type': page.schema?.type ?? 'LocalBusiness',
  name: nap.name,
  ...(meta.tagline ? { description: meta.tagline } : {}),
  url: canonical,
  ...(nap.phone ? { telephone: nap.phone } : {}),
  ...(nap.email ? { email: nap.email } : {}),
  ...(Object.keys(addr).length ? { address: { '@type': 'PostalAddress', ...addr } } : {}),
  ...(nap.serviceArea ? { areaServed: nap.serviceArea } : {}),
};

const ogImg = ogImage
  ? cldUrl(cloudinary.cloudName, ogImage, { transforms: 'f_auto,q_auto,c_fill,g_auto,w_1200,h_630' })
  : null;

// ── Roaming compass — RETIRED ───────────────────────────────────────────────
// The fixed roaming-compass overlay is removed in favour of the scroll-scrubbed
// cinematic hero (src/components/ScrollSeq.astro). The deep-tint (#ac-tint) and
// GTM landscape band remain.

// ── GTM closing band ────────────────────────────────────────────────────────
// On the HOME page (scrollSeq=true) the global scroll-scrub backdrop has parked
// on the GREEN VALLEY, so this band folds onto that green frame: no own
// landscape video / topographic fallback (that would be a SECOND, conflicting
// landscape), just the GTM copy + CTA under a soft scrim — the "navigate the
// go-to-market landscape" message folded into the green-backed resolution so it
// carries to the CTA. On every other page it keeps its self-contained landscape
// video + topographic fallback.
const gtmLandscapeId = design.gtmLandscape || '';
const gtmLandscape = !scrollSeq && gtmLandscapeId
  ? cldVideoUrl(cloudinary.cloudName, gtmLandscapeId, { width: 1920 })
  : '';
// Primary CTA reused in the band (the same one used site-wide).
const gtmCta = content.cta?.primary;
---
<!doctype html>
<html lang={meta.lang || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title || meta.businessName}</title>
    {seo.description && <meta name="description" content={seo.description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.title || meta.businessName} />
    {seo.description && <meta property="og:description" content={seo.description} />}
    <meta property="og:url" content={canonical} />
    {ogImg && <meta property="og:image" content={ogImg} />}
    <meta name="twitter:card" content={ogImg ? 'summary_large_image' : 'summary'} />

    {f.googleFontsHref && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="stylesheet" href={f.googleFontsHref} />
      </>
    )}
    <style set:html={tokenCss}></style>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    {phOn && (
      <script
        is:inline
        define:vars={{
          phKey: ph.apiKey,
          phHost: ph.host || 'https://us.i.posthog.com',
          phCookieless: ph.cookieless !== false,
          phSlug: meta.slug,
          phBusiness: meta.businessName,
        }}
      >
        (function () {
          var s = document.createElement('script');
          s.async = true;
          s.src = phHost.replace('.i.posthog.com', '-assets.i.posthog.com') + '/static/array.js';
          s.onload = function () {
            window.posthog.init(phKey, {
              api_host: phHost,
              persistence: phCookieless ? 'memory' : 'localStorage+cookie',
              person_profiles: 'identified_only',
              capture_pageview: true,
              autocapture: true,
            });
            window.posthog.register({ ac_site: phSlug, ac_business: phBusiness });
          };
          document.head.appendChild(s);
        })();
      </script>
    )}
  </head>
  <body>
    {/* ── SECTION DEEP-TINT BACKGROUND ─────────────────────────────────────
        Fixed, full-viewport color wash behind all content (z-index:-1; content
        is z-10). The rAF scroll loop below lerps its background-color through a
        sequence of DEEP NAVY tints — one per major content section — so the page
        background settles into a new deep navy as each section arrives. Tints
        are dark enough to keep Bone-White type AA. aria-hidden. */}
    <div id="ac-tint" class="ac-tint" aria-hidden="true"></div>

    {/* ── ROAMING COMPASS — RETIRED ────────────────────────────────────────
        The fixed roaming-compass overlay (#ac-roam / compassCinematic) has been
        removed: the scroll-scrubbed cinematic hero (ScrollSeq) now supersedes it
        as the page's hero. The #ac-tint deep-tint scroll choreography (rebased to
        the navy family) and the GTM landscape footer band are kept. */}

    <Nav content={content} />
    <main id="main">
      <slot />
    </main>

    {/* ── GTM CLOSING BAND ──────────────────────────────────────────────────
        Full-width closing band fused above the footer, dramatizing "we help you
        navigate the go-to-market landscape." On the HOME page the global
        scroll-scrub backdrop has bloomed into — and parked on — the GREEN
        VALLEY, so this band folds onto that green frame (.ac-gtm--folded,
        transparent, no own landscape). On every other page it keeps its
        self-contained landscape video + topographic fallback. The copy is real
        content; the media + scrim are decorative. */}
    <section
      id="ac-gtm"
      class:list={['ac-gtm', scrollSeq && 'ac-gtm--folded']}
      aria-labelledby="ac-gtm-title"
    >
      {!scrollSeq && (
        <>
          {/* Always-present dark topographic fallback (cool steel-blue contours). */}
          <div class="ac-gtm-fallback" aria-hidden="true"></div>
          {gtmLandscape && (
            <video
              id="ac-gtm-video"
              class="ac-gtm-video"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
            >
              <source src={gtmLandscape} type="video/mp4" />
            </video>
          )}
        </>
      )}
      {/* Legibility scrim so the overlaid copy stays AA over whatever's behind. */}
      <div class="ac-gtm-scrim" aria-hidden="true"></div>
      <div class="ac-gtm-inner">
        <p class="ac-label text-ink/70">The go-to-market landscape</p>
        <h2 id="ac-gtm-title" class="ac-heading mt-4 text-ink">
          We chart the route — you do the work you love.
        </h2>
        <p class="ac-subhead mt-6 max-w-2xl text-ink/80">
          Reviews, missed calls, past customers, the path to getting found — it's
          easy to get lost out there. We map every avenue that gets you paid and
          walk it for you, so you stay on the job and the booked work keeps coming.
        </p>
        {gtmCta && (
          <div class="mt-9">
            <a href={gtmCta.href} class="ac-ghost ac-ghost--accent">{gtmCta.label}</a>
          </div>
        )}
      </div>
    </section>

    <Footer content={content} />

    <script>
      // Scroll-reveal: progressive enhancement only.
      const els = document.querySelectorAll('.reveal');
      if (els.length && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // ── SECTION DEEP-TINT CHOREOGRAPHY (navy family) ───────────────────────
      // A single rAF loop washes the fixed #ac-tint background through a
      // sequence of DEEP NAVY tints — one per major content section — with a
      // "hold then snap/settle" ease at each boundary so the tint locks in as a
      // section arrives. (The roaming compass is retired; the scroll-scrubbed
      // hero — ScrollSeq — is the hero now. This drives only the section
      // background behind the content below the hero.) Tints are rebased from
      // the old near-black/oxblood/forest set to a navy family sampled from the
      // gold-on-navy art: deep navy → deeper indigo → teal-navy → slate-navy →
      // back to deep navy. All stay dark enough that Bone-White (#fffdf9) keeps
      // >= 4.5:1 AA on every tint (each tint's relative luminance ≈ 0.008–0.015,
      // well under the ~0.18 ceiling for AA against bone-white text).
      (function () {
        const tint = document.getElementById('ac-tint');
        if (!tint) return;

        const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');

        // Navy deep-tint sequence (sampled / harmonised with the new art).
        const TINTS = [
          [20, 29, 46],   // #141d2e  deep navy (hero handoff / first sections)
          [18, 26, 48],   // #121a30  deeper indigo-navy
          [17, 32, 42],   // #11202a  teal-navy
          [22, 30, 44],   // #161e2c  slate-navy
          [20, 29, 46],   // #141d2e  back to deep navy (footer / GTM band)
        ];

        const lerp = (a, b, t) => a + (b - a) * t;
        // "Hold then snap/settle" — stays near the start, then snaps late so each
        // boundary locks in crisply.
        const snap = (t) => {
          const e = t * t * (3 - 2 * t); // smoothstep base
          const s = Math.pow(t, 3.2);    // holds longer, snaps late
          return e * 0.35 + s * 0.65;
        };

        function sampleTint(p) {
          const n = TINTS.length - 1;
          const seg = Math.min(n - 1, Math.floor(p * n));
          const f = snap((p - seg / n) * n);
          const a = TINTS[seg];
          const b = TINTS[seg + 1];
          return (
            'rgb(' +
            Math.round(lerp(a[0], b[0], f)) + ',' +
            Math.round(lerp(a[1], b[1], f)) + ',' +
            Math.round(lerp(a[2], b[2], f)) + ')'
          );
        }

        let reduced = mqReduce.matches;
        let ticking = false;

        function render() {
          ticking = false;
          const doc = document.documentElement;
          const max = (doc.scrollHeight - window.innerHeight) || 1;
          const p = Math.min(1, Math.max(0, window.scrollY / max));
          tint.style.backgroundColor = sampleTint(p);
        }

        function onScroll() {
          if (reduced) return;
          if (!ticking) { ticking = true; requestAnimationFrame(render); }
        }

        function setup() {
          reduced = mqReduce.matches;
          if (reduced) {
            tint.style.backgroundColor = 'rgb(20,29,46)'; // first navy tint, static
            window.removeEventListener('scroll', onScroll);
            return;
          }
          window.addEventListener('scroll', onScroll, { passive: true });
          render();
        }

        setup();
        window.addEventListener('resize', () => { if (!reduced) render(); }, { passive: true });
        if (mqReduce.addEventListener) mqReduce.addEventListener('change', setup);

        // GTM landscape video (subpages only): if it errors (asset not yet
        // uploaded), hide it so the CSS topographic fallback carries the band.
        const gtmVideo = document.getElementById('ac-gtm-video');
        if (gtmVideo) {
          gtmVideo.addEventListener('error', function () { gtmVideo.style.display = 'none'; }, true);
          gtmVideo.querySelectorAll('source').forEach(function (sourceEl) {
            sourceEl.addEventListener('error', function () { gtmVideo.style.display = 'none'; });
          });
        }
      })();
    </script>
  </body>
</html>
