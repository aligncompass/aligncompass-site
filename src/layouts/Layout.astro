---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { cldUrl, cldVideoUrl } from '../lib/cloudinary.js';

const { content, page, ogImage } = Astro.props;
const { meta, nap, design, cloudinary, analytics } = content;
const ph = analytics?.posthog;
const phOn = Boolean(ph?.enabled && ph?.apiKey);

// Canonical = apex site + this page's path (which already includes the base/slug).
const canonical = new URL(Astro.url.pathname, Astro.site ?? meta.siteUrl).href;
const seo = page.seo ?? {};

// Design tokens → CSS variables. Single source of truth is content.json.design.
const c = design.colors;
const f = design.fonts;
const s = design.scale;
const m = design.motion ?? {};
const tokenCss = `:root{
  --ac-primary:${c.primary};--ac-primary-contrast:${c.primaryContrast};
  --ac-accent:${c.accent};--ac-accent-contrast:${c.accentContrast};
  --ac-bg:${c.bg};--ac-bg-muted:${c.bgMuted};--ac-surface:${c.surface};
  --ac-text:${c.text};--ac-text-muted:${c.textMuted};--ac-border:${c.border};
  --ac-font-heading:${f.heading};--ac-font-body:${f.body};
  --ac-radius:${s.radius};--ac-shadow:${s.shadow};--ac-max:${s.maxWidth};
  --ac-motion-duration:${m.durationMs ?? 500}ms;--ac-motion-easing:${m.easing ?? 'ease'};
}`;

// LocalBusiness/LegalService JSON-LD from the NAP — only real, supplied fields.
// Address sub-fields are included only when present, and the address object is
// omitted entirely for a virtual business with no physical location (so the
// schema never carries empty strings).
const addr = Object.fromEntries(
  Object.entries({
    streetAddress: nap.streetAddress,
    addressLocality: nap.addressLocality,
    addressRegion: nap.addressRegion,
    postalCode: nap.postalCode,
    addressCountry: nap.addressCountry,
  }).filter(([, v]) => v),
);
const schema = {
  '@context': 'https://schema.org',
  '@type': page.schema?.type ?? 'LocalBusiness',
  name: nap.name,
  ...(meta.tagline ? { description: meta.tagline } : {}),
  url: canonical,
  ...(nap.phone ? { telephone: nap.phone } : {}),
  ...(nap.email ? { email: nap.email } : {}),
  ...(Object.keys(addr).length ? { address: { '@type': 'PostalAddress', ...addr } } : {}),
  ...(nap.serviceArea ? { areaServed: nap.serviceArea } : {}),
};

const ogImg = ogImage
  ? cldUrl(cloudinary.cloudName, ogImage, { transforms: 'f_auto,q_auto,c_fill,g_auto,w_1200,h_630' })
  : null;

// ── Roaming compass (single, persistent) ───────────────────────────────────
// ONE compass element rendered once here in the layout as a fixed overlay layer
// that sits BEHIND all page content. It uses the Higgsfield-generated, Cloudinary-
// hosted looping <video> (compass-solid-loop) with the still (compass-solid-still)
// as poster + reduced-motion fallback. A scroll-driven rAF handler (below)
// repositions / scales / rotates it between waypoints as the user scrolls so it
// "zips and zaps" around the page. Asset ids are constants (the compass motif is
// fixed for this site); platform stays Cloudinary, asset stays the Higgsfield one.
const compassStillId = 'aligncompass-site/compass-solid-still';
// The roaming compass video is now driven by content.json design.compassCinematic
// (the cinematic open/spin/slam asset). It defaults to the existing solid loop so
// preview works today; swap design.compassCinematic to the cinematic id when ready.
// design.* poster still is unchanged.
const compassVideoId = design.compassCinematic || 'aligncompass-site/compass-solid-loop';
const compassStill = cldUrl(cloudinary.cloudName, compassStillId, { width: 900, transforms: 'f_auto,q_auto' });
const compassVideo = cldVideoUrl(cloudinary.cloudName, compassVideoId, { width: 900 });

// ── GTM landscape band (footer) ─────────────────────────────────────────────
// A full-width cinematic "go-to-market landscape you traverse" band fused above
// the footer. Driven by content.json design.gtmLandscape (a Cloudinary video
// public id). If the video fails / is missing, a dark CSS topographic backdrop
// (.ac-gtm-fallback) shows through so the band always looks intentional.
const gtmLandscapeId = design.gtmLandscape || '';
const gtmLandscape = gtmLandscapeId
  ? cldVideoUrl(cloudinary.cloudName, gtmLandscapeId, { width: 1920 })
  : '';
// Primary CTA reused in the band (the same one used site-wide).
const gtmCta = content.cta?.primary;
---
<!doctype html>
<html lang={meta.lang || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title || meta.businessName}</title>
    {seo.description && <meta name="description" content={seo.description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.title || meta.businessName} />
    {seo.description && <meta property="og:description" content={seo.description} />}
    <meta property="og:url" content={canonical} />
    {ogImg && <meta property="og:image" content={ogImg} />}
    <meta name="twitter:card" content={ogImg ? 'summary_large_image' : 'summary'} />

    {f.googleFontsHref && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="stylesheet" href={f.googleFontsHref} />
      </>
    )}
    <style set:html={tokenCss}></style>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    {phOn && (
      <script
        is:inline
        define:vars={{
          phKey: ph.apiKey,
          phHost: ph.host || 'https://us.i.posthog.com',
          phCookieless: ph.cookieless !== false,
          phSlug: meta.slug,
          phBusiness: meta.businessName,
        }}
      >
        (function () {
          var s = document.createElement('script');
          s.async = true;
          s.src = phHost.replace('.i.posthog.com', '-assets.i.posthog.com') + '/static/array.js';
          s.onload = function () {
            window.posthog.init(phKey, {
              api_host: phHost,
              persistence: phCookieless ? 'memory' : 'localStorage+cookie',
              person_profiles: 'identified_only',
              capture_pageview: true,
              autocapture: true,
            });
            window.posthog.register({ ac_site: phSlug, ac_business: phBusiness });
          };
          document.head.appendChild(s);
        })();
      </script>
    )}
  </head>
  <body>
    {/* ── SECTION DEEP-TINT BACKGROUND ─────────────────────────────────────
        Fixed, full-viewport color wash that sits BEHIND the roaming compass
        (z-index:-1; compass layer is 0, content is 10). Its color is a CSS
        custom property (--ac-tint) lerped by the rAF scroll loop through a
        sequence of deep-tinted near-blacks — one per major section — so the
        page background settles into a new deep tint as each section arrives.
        Tints are very dark (AA-safe with Bone-White type). aria-hidden. */}
    <div id="ac-tint" class="ac-tint" aria-hidden="true"></div>

    {/* ── ROAMING COMPASS ──────────────────────────────────────────────────
        Single persistent compass that roams the whole page on scroll. Fixed
        full-viewport layer behind all content (z-index 0; page content is z-10).
        The compass moves via transform on the inner .ac-roam-compass element
        (driven by the rAF scroll script below); the outer fixed layer also
        carries a subtle scrim/vignette so Bone-White type keeps AA contrast.
        Under prefers-reduced-motion / small screens the script holds it static
        and the still poster is shown (video paused). aria-hidden — decoration. */}
    <div id="ac-roam" class="ac-roam" aria-hidden="true">
      <div class="ac-roam-compass" id="ac-roam-compass">
        <div class="ac-compass-halo"></div>
        <video
          id="ac-roam-video"
          class="ac-roam-media ac-reduced-hide"
          muted
          loop
          playsinline
          preload="metadata"
          poster={compassStill}
        >
          <source src={compassVideo} type="video/mp4" />
        </video>
        {/* Reduced-motion / no-video fallback still (also used on small screens). */}
        <img
          id="ac-roam-still"
          class="ac-roam-media ac-reduced-show"
          src={compassStill}
          alt=""
          loading="eager"
          decoding="async"
        />
      </div>
      {/* Legibility scrim/vignette painted over the compass, under the text. */}
      <div class="ac-roam-scrim"></div>
    </div>

    <Nav content={content} />
    <main id="main">
      <slot />
    </main>

    {/* ── GTM LANDSCAPE BAND ────────────────────────────────────────────────
        Full-width cinematic band fused above the footer: a landscape the
        visitor appears to traverse, dramatizing "we help you navigate the
        go-to-market landscape." A muted/looping/playsinline <video> (Cloudinary,
        design.gtmLandscape) plays under a dark gradient scrim with short GTM
        copy + the primary CTA. If the video can't load, the .ac-gtm-fallback
        steel-blue contour backdrop carries the band. The roaming compass'
        final waypoint lands in this band, as if leading along the path.
        Decorative media is aria-hidden; the copy is real content. */}
    <section id="ac-gtm" class="ac-gtm" aria-labelledby="ac-gtm-title">
      {/* Always-present dark topographic fallback (cool steel-blue contours). */}
      <div class="ac-gtm-fallback" aria-hidden="true"></div>
      {gtmLandscape && (
        <video
          id="ac-gtm-video"
          class="ac-gtm-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        >
          <source src={gtmLandscape} type="video/mp4" />
        </video>
      )}
      {/* Legibility scrim so the overlaid copy stays AA over the landscape. */}
      <div class="ac-gtm-scrim" aria-hidden="true"></div>
      <div class="ac-gtm-inner">
        <p class="ac-label text-ink/70">The go-to-market landscape</p>
        <h2 id="ac-gtm-title" class="ac-heading mt-4 text-ink">
          We chart the route — you do the work you love.
        </h2>
        <p class="ac-subhead mt-6 max-w-2xl text-ink/80">
          Reviews, missed calls, past customers, the path to getting found — it's
          easy to get lost out there. We map every avenue that gets you paid and
          walk it for you, so you stay on the job and the booked work keeps coming.
        </p>
        {gtmCta && (
          <div class="mt-9">
            <a href={gtmCta.href} class="ac-ghost ac-ghost--accent">{gtmCta.label}</a>
          </div>
        )}
      </div>
    </section>

    <Footer content={content} />

    <script>
      // Scroll-reveal: progressive enhancement only.
      const els = document.querySelectorAll('.reveal');
      if (els.length && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // ── CINEMATIC SCROLL CHOREOGRAPHY ──────────────────────────────────────
      // One rAF loop drives three synced layers as the page scrolls:
      //   1) SECTION DEEP-TINT — the fixed #ac-tint background washes through a
      //      sequence of deep-tinted near-blacks, one per major section, with a
      //      "hold then snap/settle" ease at each boundary so the tint locks in.
      //   2) ROAMING COMPASS — the single compass drifts calmly through each
      //      section, then PUNCHES (quick scale-up + a touch of rotation + a
      //      forward "slam") exactly at each section boundary, landing as the
      //      tint snaps, then settles. Final waypoint lands in the GTM band.
      //   3) (compass video itself carries the open/spin/slam motion — swapped
      //      in via design.compassCinematic.)
      //
      // Everything is transform/opacity + one CSS color var, written inside a
      // single rAF, GPU-friendly, with will-change set. Reduced-motion = static
      // still + first tint, no motion. Mobile = calmer/smaller motion.
      (function () {
        const layer = document.getElementById('ac-roam');
        const el = document.getElementById('ac-roam-compass');
        const tint = document.getElementById('ac-tint');
        const video = document.getElementById('ac-roam-video');
        const still = document.getElementById('ac-roam-still');
        if (!layer || !el) return;

        const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
        const mqSmall = window.matchMedia('(max-width: 767px)');

        // ── DEEP-TINT SEQUENCE ───────────────────────────────────────────────
        // One deep, desaturated near-black per major section, in scroll order:
        // near-black (hero) → ink-blue-black → oxblood-black → forest-black →
        // slate-black → back to near-black (footer/GTM band). All very dark so
        // Bone-White (#fffdf9) stays >= 4.5:1 AA on every tint (verified: each
        // tint's luminance is far below the ~#3a3a3a ceiling for AA vs bone).
        const TINTS = [
          [14, 18, 22],   // #0e1216  near-black (hero)
          [14, 19, 32],   // #0e1320  ink-blue-black
          [26, 15, 18],   // #1a0f12  oxblood-black
          [12, 20, 15],   // #0c140f  forest-black
          [17, 21, 26],   // #11151a  slate-black
          [14, 18, 22],   // #0e1216  back to near-black (footer / GTM band)
        ];

        const lerp = (a, b, t) => a + (b - a) * t;
        // Smootherstep — fluid drift between waypoints.
        const smoother = (t) => t * t * t * (t * (t * 6 - 15) + 10);
        // "Hold then snap/settle" for the tint + the boundary punch: stays near
        // the start, then snaps over the last third and overshoots slightly into
        // a settle. Gives each boundary a crisp lock-in synced with the slam.
        const snap = (t) => {
          // ease that holds (slow start) then snaps (fast finish), with a tiny
          // settle via a back-ease near the end.
          const e = t * t * (3 - 2 * t); // smoothstep base
          const s = Math.pow(t, 3.2);    // holds longer, snaps late
          return e * 0.35 + s * 0.65;
        };

        // Compass waypoints across scroll progress (t: 0→1). x = vw offset,
        // y = vh offset from viewport centre; s = scale; r = rot deg; o = opacity.
        // There is one waypoint per tint boundary so the compass settles into
        // each section; the final point lands lower-centre (into the GTM band).
        const WAYPOINTS = [
          { t: 0.0,  x: 24,  y: -4,  s: 1.0,  r: -8,  o: 0.95 }, // hero
          { t: 0.2,  x: -28, y: 16,  s: 0.66, r: 22,  o: 0.7 },  // ink-blue
          { t: 0.4,  x: 30,  y: -20, s: 0.8,  r: -30, o: 0.78 }, // oxblood
          { t: 0.6,  x: -8,  y: 6,   s: 1.12, r: 12,  o: 0.6 },  // forest (centre, big, dim)
          { t: 0.8,  x: 26,  y: 14,  s: 0.72, r: 40,  o: 0.72 }, // slate
          { t: 1.0,  x: 0,   y: 24,  s: 0.92, r: -10, o: 0.9 },  // settles INTO GTM band (lower-centre)
        ];

        // Calmer/tighter path for small screens (less travel + rotation).
        const WAYPOINTS_SMALL = [
          { t: 0.0,  x: 8,   y: -6,  s: 0.8,  r: -6,  o: 0.5 },
          { t: 0.25, x: -10, y: 8,   s: 0.6,  r: 12,  o: 0.42 },
          { t: 0.5,  x: 9,   y: -7,  s: 0.66, r: -14, o: 0.46 },
          { t: 0.75, x: -8,  y: 6,   s: 0.62, r: 12,  o: 0.46 },
          { t: 1.0,  x: 0,   y: 12,  s: 0.7,  r: -6,  o: 0.5 },
        ];

        // Boundary slam profile: scale + rotation kick that peaks AT each
        // waypoint boundary and decays as we settle into the section. We compute
        // a per-segment "nearness to boundary" and add a short punch. Mobile and
        // the kick are scaled down so it's crisp, not nauseating.
        const SLAM_SCALE = 0.16;  // extra scale at the punch peak (desktop)
        const SLAM_ROT = 6;       // extra degrees at the punch peak (desktop)
        const SLAM_SMALL = 0.5;   // mobile damping

        function sampleTint(p) {
          const n = TINTS.length - 1;
          const seg = Math.min(n - 1, Math.floor(p * n));
          const f = snap((p - seg / n) * n); // hold-then-snap within the segment
          const a = TINTS[seg];
          const b = TINTS[seg + 1];
          return (
            'rgb(' +
            Math.round(lerp(a[0], b[0], f)) + ',' +
            Math.round(lerp(a[1], b[1], f)) + ',' +
            Math.round(lerp(a[2], b[2], f)) + ')'
          );
        }

        function sampleCompass(points, p, slamFactor) {
          if (p <= points[0].t) return Object.assign({}, points[0], { punch: 0 });
          const last = points[points.length - 1];
          if (p >= last.t) return Object.assign({}, last, { punch: 0 });
          for (let i = 0; i < points.length - 1; i++) {
            const a = points[i];
            const b = points[i + 1];
            if (p >= a.t && p <= b.t) {
              const lf = (p - a.t) / (b.t - a.t);
              const f = smoother(lf);
              // Punch peaks near the END of the segment (arriving at boundary b)
              // and at the very START (just left boundary a): a quick bump that
              // is strongest right at the snap, then decays into the section.
              const nearEnd = Math.pow(Math.max(0, (lf - 0.78) / 0.22), 2); // 0→1 approaching b
              const nearStart = Math.pow(Math.max(0, (0.16 - lf) / 0.16), 2); // 1→0 leaving a
              const punch = Math.min(1, nearEnd + nearStart) * slamFactor;
              return {
                x: lerp(a.x, b.x, f),
                y: lerp(a.y, b.y, f),
                s: lerp(a.s, b.s, f),
                r: lerp(a.r, b.r, f),
                o: lerp(a.o, b.o, f),
                punch: punch,
              };
            }
          }
          return Object.assign({}, last, { punch: 0 });
        }

        // Static pose (reduced-motion / fallback): off-centre, no motion, first
        // tint, show the still, pause the video.
        function applyStatic() {
          el.style.transform = 'translate3d(18vw, -2vh, 0) scale(0.95) rotate(-6deg)';
          el.style.opacity = '0.55';
          if (tint) tint.style.backgroundColor = 'rgb(14,18,22)';
          if (video) {
            try { video.pause(); } catch (e) {}
            video.style.display = 'none';
          }
          if (still) still.style.display = 'block';
        }

        let reduced = mqReduce.matches;
        let small = mqSmall.matches;
        let ticking = false;

        function render() {
          ticking = false;
          const doc = document.documentElement;
          const max = (doc.scrollHeight - window.innerHeight) || 1;
          const p = Math.min(1, Math.max(0, window.scrollY / max));

          // 1) Deep-tint background.
          if (tint) tint.style.backgroundColor = sampleTint(p);

          // 2) Roaming compass + boundary slam.
          const pts = small ? WAYPOINTS_SMALL : WAYPOINTS;
          const slamScale = SLAM_SCALE * (small ? SLAM_SMALL : 1);
          const slamRot = SLAM_ROT * (small ? SLAM_SMALL : 1);
          const v = sampleCompass(pts, p, 1);
          // The forward "slam": a quick scale-up + a touch of rotation kick,
          // layered onto the drifting pose, peaking at each boundary.
          const s = v.s + v.punch * slamScale;
          const r = v.r + v.punch * slamRot;
          el.style.transform =
            'translate3d(' + v.x + 'vw, ' + v.y + 'vh, 0) scale(' + s + ') rotate(' + r + 'deg)';
          el.style.opacity = String(v.o);
        }

        function onScroll() {
          if (reduced) return;
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(render);
          }
        }

        function setup() {
          reduced = mqReduce.matches;
          small = mqSmall.matches;
          if (reduced) {
            applyStatic();
            window.removeEventListener('scroll', onScroll);
            return;
          }
          if (video) {
            video.style.display = 'block';
            const playPromise = video.play();
            if (playPromise && playPromise.catch) playPromise.catch(() => {});
          }
          if (still) still.style.display = 'none';
          window.addEventListener('scroll', onScroll, { passive: true });
          render(); // initial pose + tint
        }

        setup();
        window.addEventListener('resize', () => {
          const wasReduced = reduced;
          const wasSmall = small;
          reduced = mqReduce.matches;
          small = mqSmall.matches;
          if (reduced !== wasReduced || small !== wasSmall) {
            setup();
          } else if (!reduced) {
            render();
          }
        }, { passive: true });
        if (mqReduce.addEventListener) mqReduce.addEventListener('change', setup);

        // GTM landscape video: if it errors (asset not yet uploaded), hide it so
        // the CSS topographic fallback carries the band — band always looks
        // intentional.
        const gtmVideo = document.getElementById('ac-gtm-video');
        if (gtmVideo) {
          gtmVideo.addEventListener('error', function () { gtmVideo.style.display = 'none'; }, true);
          gtmVideo.querySelectorAll('source').forEach(function (sourceEl) {
            sourceEl.addEventListener('error', function () { gtmVideo.style.display = 'none'; });
          });
        }
      })();
    </script>
  </body>
</html>
