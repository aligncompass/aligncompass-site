---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { cldUrl, cldVideoUrl } from '../lib/cloudinary.js';

const { content, page, ogImage } = Astro.props;
const { meta, nap, design, cloudinary, analytics } = content;
const ph = analytics?.posthog;
const phOn = Boolean(ph?.enabled && ph?.apiKey);

// Canonical = apex site + this page's path (which already includes the base/slug).
const canonical = new URL(Astro.url.pathname, Astro.site ?? meta.siteUrl).href;
const seo = page.seo ?? {};

// Design tokens → CSS variables. Single source of truth is content.json.design.
const c = design.colors;
const f = design.fonts;
const s = design.scale;
const m = design.motion ?? {};
const tokenCss = `:root{
  --ac-primary:${c.primary};--ac-primary-contrast:${c.primaryContrast};
  --ac-accent:${c.accent};--ac-accent-contrast:${c.accentContrast};
  --ac-bg:${c.bg};--ac-bg-muted:${c.bgMuted};--ac-surface:${c.surface};
  --ac-text:${c.text};--ac-text-muted:${c.textMuted};--ac-border:${c.border};
  --ac-font-heading:${f.heading};--ac-font-body:${f.body};
  --ac-radius:${s.radius};--ac-shadow:${s.shadow};--ac-max:${s.maxWidth};
  --ac-motion-duration:${m.durationMs ?? 500}ms;--ac-motion-easing:${m.easing ?? 'ease'};
}`;

// LocalBusiness/LegalService JSON-LD from the NAP — only real, supplied fields.
// Address sub-fields are included only when present, and the address object is
// omitted entirely for a virtual business with no physical location (so the
// schema never carries empty strings).
const addr = Object.fromEntries(
  Object.entries({
    streetAddress: nap.streetAddress,
    addressLocality: nap.addressLocality,
    addressRegion: nap.addressRegion,
    postalCode: nap.postalCode,
    addressCountry: nap.addressCountry,
  }).filter(([, v]) => v),
);
const schema = {
  '@context': 'https://schema.org',
  '@type': page.schema?.type ?? 'LocalBusiness',
  name: nap.name,
  ...(meta.tagline ? { description: meta.tagline } : {}),
  url: canonical,
  ...(nap.phone ? { telephone: nap.phone } : {}),
  ...(nap.email ? { email: nap.email } : {}),
  ...(Object.keys(addr).length ? { address: { '@type': 'PostalAddress', ...addr } } : {}),
  ...(nap.serviceArea ? { areaServed: nap.serviceArea } : {}),
};

const ogImg = ogImage
  ? cldUrl(cloudinary.cloudName, ogImage, { transforms: 'f_auto,q_auto,c_fill,g_auto,w_1200,h_630' })
  : null;

// ── Roaming compass (single, persistent) ───────────────────────────────────
// ONE compass element rendered once here in the layout as a fixed overlay layer
// that sits BEHIND all page content. It uses the Higgsfield-generated, Cloudinary-
// hosted looping <video> (compass-solid-loop) with the still (compass-solid-still)
// as poster + reduced-motion fallback. A scroll-driven rAF handler (below)
// repositions / scales / rotates it between waypoints as the user scrolls so it
// "zips and zaps" around the page. Asset ids are constants (the compass motif is
// fixed for this site); platform stays Cloudinary, asset stays the Higgsfield one.
const compassStillId = 'aligncompass-site/compass-solid-still';
const compassVideoId = 'aligncompass-site/compass-solid-loop';
const compassStill = cldUrl(cloudinary.cloudName, compassStillId, { width: 900, transforms: 'f_auto,q_auto' });
const compassVideo = cldVideoUrl(cloudinary.cloudName, compassVideoId, { width: 900 });
---
<!doctype html>
<html lang={meta.lang || 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.title || meta.businessName}</title>
    {seo.description && <meta name="description" content={seo.description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.title || meta.businessName} />
    {seo.description && <meta property="og:description" content={seo.description} />}
    <meta property="og:url" content={canonical} />
    {ogImg && <meta property="og:image" content={ogImg} />}
    <meta name="twitter:card" content={ogImg ? 'summary_large_image' : 'summary'} />

    {f.googleFontsHref && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="stylesheet" href={f.googleFontsHref} />
      </>
    )}
    <style set:html={tokenCss}></style>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    {phOn && (
      <script
        is:inline
        define:vars={{
          phKey: ph.apiKey,
          phHost: ph.host || 'https://us.i.posthog.com',
          phCookieless: ph.cookieless !== false,
          phSlug: meta.slug,
          phBusiness: meta.businessName,
        }}
      >
        (function () {
          var s = document.createElement('script');
          s.async = true;
          s.src = phHost.replace('.i.posthog.com', '-assets.i.posthog.com') + '/static/array.js';
          s.onload = function () {
            window.posthog.init(phKey, {
              api_host: phHost,
              persistence: phCookieless ? 'memory' : 'localStorage+cookie',
              person_profiles: 'identified_only',
              capture_pageview: true,
              autocapture: true,
            });
            window.posthog.register({ ac_site: phSlug, ac_business: phBusiness });
          };
          document.head.appendChild(s);
        })();
      </script>
    )}
  </head>
  <body>
    {/* ── ROAMING COMPASS ──────────────────────────────────────────────────
        Single persistent compass that roams the whole page on scroll. Fixed
        full-viewport layer behind all content (z-index 0; page content is z-10).
        The compass moves via transform on the inner .ac-roam-compass element
        (driven by the rAF scroll script below); the outer fixed layer also
        carries a subtle scrim/vignette so Bone-White type keeps AA contrast.
        Under prefers-reduced-motion / small screens the script holds it static
        and the still poster is shown (video paused). aria-hidden — decoration. */}
    <div id="ac-roam" class="ac-roam" aria-hidden="true">
      <div class="ac-roam-compass" id="ac-roam-compass">
        <div class="ac-compass-halo"></div>
        <video
          id="ac-roam-video"
          class="ac-roam-media ac-reduced-hide"
          muted
          loop
          playsinline
          preload="metadata"
          poster={compassStill}
        >
          <source src={compassVideo} type="video/mp4" />
        </video>
        {/* Reduced-motion / no-video fallback still (also used on small screens). */}
        <img
          id="ac-roam-still"
          class="ac-roam-media ac-reduced-show"
          src={compassStill}
          alt=""
          loading="eager"
          decoding="async"
        />
      </div>
      {/* Legibility scrim/vignette painted over the compass, under the text. */}
      <div class="ac-roam-scrim"></div>
    </div>

    <Nav content={content} />
    <main id="main">
      <slot />
    </main>
    <Footer content={content} />

    <script>
      // Scroll-reveal: progressive enhancement only.
      const els = document.querySelectorAll('.reveal');
      if (els.length && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // ── ROAMING COMPASS: scroll-driven motion ──────────────────────────────
      // A single compass "zips and zaps" between waypoints as the page scrolls.
      // We compute scroll progress p (0 at top → 1 at bottom), find which two
      // waypoints we're between, ease the local segment fraction, and lerp the
      // (x, y, scale, rotate, opacity) values. The result is written to a single
      // transform + opacity on the inner element inside requestAnimationFrame so
      // it stays GPU-friendly and never blocks the scroll thread.
      //
      // Waypoints are expressed in viewport units relative to the layer centre:
      //   x/y are vw/vh offsets from centre (so the path is responsive),
      //   scale is multiplier, rot is degrees, op is opacity.
      // The eased path (hero → lower-left → top-right → centre → right → exit)
      // gives the playful "darting around the page" feel while keeping the
      // compass behind dense text at lower opacity.
      (function () {
        const layer = document.getElementById('ac-roam');
        const el = document.getElementById('ac-roam-compass');
        const video = document.getElementById('ac-roam-video');
        const still = document.getElementById('ac-roam-still');
        if (!layer || !el) return;

        const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
        const mqSmall = window.matchMedia('(max-width: 767px)');

        // Keyframe waypoints across scroll progress (t: 0→1). x = vw offset,
        // y = vh offset from viewport centre; s = scale; r = rotation deg; o = opacity.
        const WAYPOINTS = [
          { t: 0.0, x: 24, y: -4, s: 1.0, r: -8, o: 0.95 }, // hero: right-of-centre, large
          { t: 0.22, x: -30, y: 18, s: 0.62, r: 26, o: 0.7 }, // darts to lower-left, smaller
          { t: 0.44, x: 30, y: -22, s: 0.78, r: -34, o: 0.78 }, // zips to top-right
          { t: 0.62, x: -6, y: 4, s: 1.18, r: 12, o: 0.6 }, // sweeps to centre, big (dimmed behind text)
          { t: 0.8, x: 28, y: 16, s: 0.7, r: 48, o: 0.72 }, // darts to lower-right
          { t: 1.0, x: -22, y: -10, s: 0.9, r: -18, o: 0.85 }, // settles upper-left near footer
        ];

        // Calmer, tighter path for small screens (less travel, less rotation) so
        // mobile stays smooth and the compass never crowds the narrow column.
        const WAYPOINTS_SMALL = [
          { t: 0.0, x: 8, y: -6, s: 0.8, r: -6, o: 0.5 },
          { t: 0.35, x: -10, y: 10, s: 0.6, r: 14, o: 0.42 },
          { t: 0.7, x: 10, y: -8, s: 0.7, r: -16, o: 0.46 },
          { t: 1.0, x: -6, y: 6, s: 0.7, r: 8, o: 0.5 },
        ];

        const lerp = (a, b, t) => a + (b - a) * t;
        // Smootherstep easing for fluid, slightly springy segment transitions.
        const ease = (t) => t * t * t * (t * (t * 6 - 15) + 10);

        function sample(points, p) {
          if (p <= points[0].t) return points[0];
          if (p >= points[points.length - 1].t) return points[points.length - 1];
          for (let i = 0; i < points.length - 1; i++) {
            const a = points[i];
            const b = points[i + 1];
            if (p >= a.t && p <= b.t) {
              const f = ease((p - a.t) / (b.t - a.t));
              return {
                x: lerp(a.x, b.x, f),
                y: lerp(a.y, b.y, f),
                s: lerp(a.s, b.s, f),
                r: lerp(a.r, b.r, f),
                o: lerp(a.o, b.o, f),
              };
            }
          }
          return points[points.length - 1];
        }

        // Apply a single static pose (reduced-motion / fallback): a tasteful
        // off-centre placement, no motion, show the still, pause the video.
        function applyStatic() {
          el.style.transform = 'translate3d(18vw, -2vh, 0) scale(0.95) rotate(-6deg)';
          el.style.opacity = '0.55';
          if (video) {
            try { video.pause(); } catch (e) {}
            video.style.display = 'none';
          }
          if (still) still.style.display = 'block';
        }

        let reduced = mqReduce.matches;
        let small = mqSmall.matches;
        let ticking = false;

        function render() {
          ticking = false;
          const doc = document.documentElement;
          const max = (doc.scrollHeight - window.innerHeight) || 1;
          const p = Math.min(1, Math.max(0, window.scrollY / max));
          const pts = small ? WAYPOINTS_SMALL : WAYPOINTS;
          const v = sample(pts, p);
          // translate uses vw/vh so the path scales with the viewport; the layer
          // is centred (flex), so these are offsets from centre.
          el.style.transform =
            'translate3d(' + v.x + 'vw, ' + v.y + 'vh, 0) scale(' + v.s + ') rotate(' + v.r + 'deg)';
          el.style.opacity = String(v.o);
        }

        function onScroll() {
          if (reduced) return;
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(render);
          }
        }

        function setup() {
          reduced = mqReduce.matches;
          small = mqSmall.matches;
          if (reduced) {
            applyStatic();
            window.removeEventListener('scroll', onScroll);
            return;
          }
          // Motion path: show + autoplay the video (still hidden), bind scroll.
          if (video) {
            video.style.display = 'block';
            const playPromise = video.play();
            if (playPromise && playPromise.catch) playPromise.catch(() => {});
          }
          if (still) still.style.display = 'none';
          window.addEventListener('scroll', onScroll, { passive: true });
          render(); // initial pose
        }

        setup();
        window.addEventListener('resize', () => {
          // Re-evaluate small-screen state + recompute pose on resize/orientation.
          const wasReduced = reduced;
          const wasSmall = small;
          reduced = mqReduce.matches;
          small = mqSmall.matches;
          if (reduced !== wasReduced || small !== wasSmall) {
            setup();
          } else if (!reduced) {
            render();
          }
        }, { passive: true });
        // React to OS-level reduced-motion changes mid-session.
        if (mqReduce.addEventListener) mqReduce.addEventListener('change', setup);
      })();
    </script>
  </body>
</html>
