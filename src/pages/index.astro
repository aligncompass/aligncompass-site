        <span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-500"></span>
        <span class="whitespace-nowrap">Lock in <span class="font-bold">$35/mo</span> for year one</span>
        <span aria-hidden="true" class="text-amber-600">→</span>
      </a>
    </div>

    <!-- Phone mockup: Google Maps local pack showing "your business" at #1 -->
    <div class="reveal mt-20 mx-auto flex justify-center" data-delay="500">
