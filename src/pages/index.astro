                <path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
              <span class="text-sm text-slate-700">plumber near me</span>
            </div>

            <!-- Map preview -->
            <div class="mx-3 mt-3 h-24 rounded-2xl relative overflow-hidden bg-gradient-to-br from-brand-50 via-slate-100 to-slate-200">
              <svg class="absolute inset-0 w-full h-full opacity-50" viewBox="0 0 200 96" fill="none" aria-hidden="true">
                <path d="M0 60 Q40 30 80 50 T160 40 T200 55" stroke="rgb(148,163,184)" stroke-width="0.8" fill="none"/>
                <path d="M0 20 Q60 50 100 30 T200 25" stroke="rgb(148,163,184)" stroke-width="0.6" fill="none"/>
                <path d="M30 0 L30 96" stroke="rgb(203,213,225)" stroke-width="0.5"/>
                <path d="M120 0 L120 96" stroke="rgb(203,213,225)" stroke-width="0.5"/>
                <path d="M170 0 L170 96" stroke="rgb(203,213,225)" stroke-width="0.5"/>
              </svg>
              <!-- Pin -->
              <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
