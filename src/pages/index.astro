        <!-- Glow behind phone -->
        <div aria-hidden="true" class="absolute -inset-6 -z-10 rounded-[3.5rem] bg-gradient-to-br from-brand-500/30 via-brand-300/20 to-transparent blur-2xl"></div>

        <!-- Phone frame -->
        <div class="relative w-[280px] sm:w-[320px] rounded-[2.75rem] bg-slate-950 p-2.5 shadow-[0_40px_80px_-20px_rgba(15,23,42,0.55)] ring-1 ring-slate-900/40">
          <div class="relative rounded-[2.25rem] bg-slate-50 overflow-hidden">
            <!-- Notch / island -->
            <div class="absolute left-1/2 -translate-x-1/2 top-2 z-10 h-5 w-24 rounded-full bg-slate-950"></div>

            <!-- Top spacer -->
            <div class="h-9"></div>

            <!-- Search bar -->
            <div class="mx-3 mt-2 flex items-center gap-2.5 rounded-full bg-white shadow-sm border border-slate-200 px-4 py-2.5">
