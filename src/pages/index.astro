const contactEmail = 'info@aligncompass.com';
const demoMailto = `mailto:${contactEmail}?subject=I%27d%20like%20a%20demo&body=Business%20name%3A%0ACity%3A%0AWhat%20you%20do%3A%0AWho%20you%20serve%3A%0A`;
const phone = '305-216-2975';
const phoneTel = 'tel:+13052162975';
---

<Layout>
  <!-- ============================== NAV ============================== -->
  <nav class="scroll-nav sticky top-0 z-50 backdrop-blur-xl bg-white/75 border-b border-slate-200/60">
    <div class="max-w-6xl mx-auto px-6 py-3.5 flex items-center justify-between">
      <a href="#top" class="flex items-center gap-2 text-slate-900 font-semibold tracking-tight">
        <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6 text-brand-600" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="M12 4l2.2 5.8L20 12l-5.8 2.2L12 20l-2.2-5.8L4 12l5.8-2.2z" fill="currentColor"></path>
        </svg>
        <span>AlignCompass</span>
      </a>
      <div class="flex items-center gap-2 sm:gap-5 text-sm">
        <a href="#how" class="hidden md:inline text-slate-600 hover:text-slate-900 transition">How it works</a>
        <a href="#pricing" class="hidden md:inline text-slate-600 hover:text-slate-900 transition">Pricing</a>
        <a href="#faq" class="hidden md:inline text-slate-600 hover:text-slate-900 transition">FAQ</a>
        <a
          href={phoneTel}
          class="hidden sm:inline-flex items-center gap-1.5 text-slate-700 hover:text-slate-900 font-medium transition"
        >
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{phone}</span>
        </a>
        <a
          href={demoMailto}
          class="inline-flex items-center rounded-full bg-slate-900 px-4 py-2 text-white font-medium hover:bg-slate-800 transition shadow-sm ring-1 ring-slate-900/10"
        >
          Get my free demo
        </a>
      </div>
    </div>
  </nav>

  <!-- ============================== HERO ============================== -->
  <header id="top" class="relative px-6 pt-14 pb-28 sm:pt-20 sm:pb-32 overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-50 via-white to-white"></div>
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_70%_55%_at_50%_-5%,rgba(13,148,136,0.14),transparent_72%)]"></div>
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_50%_45%_at_85%_10%,rgba(15,23,42,0.06),transparent_70%)]"></div>

    <div class="max-w-5xl mx-auto text-center">
      <span class="reveal inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/80 backdrop-blur px-4 py-1.5 text-xs font-medium text-slate-600 shadow-sm">
        <span class="relative inline-flex">
          <span class="inline-block w-2 h-2 rounded-full bg-brand-500"></span>
          <span class="absolute inset-0 inline-block w-2 h-2 rounded-full bg-brand-500 animate-ping opacity-75"></span>
        </span>
        Booking new local businesses this week
      </span>

      <h1 class="reveal mt-7 text-5xl sm:text-7xl font-semibold tracking-tight text-slate-900 leading-[1.02]" data-delay="100">
        More local customers.
        <span class="block bg-gradient-to-br from-brand-600 to-brand-800 bg-clip-text text-transparent">While you sleep.</span>
      </h1>

      <p class="reveal mt-7 text-lg sm:text-2xl text-slate-600 max-w-2xl mx-auto leading-relaxed font-normal" data-delay="200">
        A custom website built exactly for your business — <span class="text-slate-900 font-semibold">free to review</span>
        before you ever pay a cent. So when somebody Googles what you do, they find <em class="not-italic font-medium text-slate-900">you</em> —
        not the competitor down the street.
      </p>

      <div class="reveal mt-10 flex flex-col sm:flex-row items-center justify-center gap-3" data-delay="300">
        <a
          href={demoMailto}
          class="w-full sm:w-auto inline-flex items-center justify-center rounded-full bg-slate-900 px-8 py-4 text-white font-semibold text-base hover:bg-slate-800 transition shadow-lg shadow-slate-900/15 ring-1 ring-slate-900/10 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-slate-900/20"
