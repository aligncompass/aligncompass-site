                  <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-3 bg-brand-600"></div>
                </div>
              </div>
            </div>

            <!-- Map Pack header -->
            <div class="mx-3 mt-3 flex items-center justify-between text-[10px] font-semibold text-slate-500 uppercase tracking-wider">
              <span>3 places near you</span>
              <span class="text-brand-700">See all</span>
            </div>

            <!-- Result 1: YOUR BUSINESS, featured -->
            <div class="mx-3 mt-2 rounded-2xl bg-white ring-2 ring-brand-500/50 p-3 shadow-md">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-white" aria-hidden="true">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/>
                    <path d="M12 4l2.2 5.8L20 12l-5.8 2.2L12 20l-2.2-5.8L4 12l5.8-2.2z" fill="currentColor"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-xs font-bold text-slate-900 truncate">Your Business</div>
                  <div class="flex items-center gap-1 mt-0.5">
                    <span class="text-[10px] text-amber-600 font-semibold">★ 4.9</span>
                    <span class="text-[10px] text-slate-400">·</span>
                    <span class="text-[10px] text-brand-700 font-semibold">Open now</span>
