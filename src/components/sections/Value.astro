---
const { section } = Astro.props;
const items = section.items ?? [];
---
<section class="bg-bg">
  <div class="mx-auto max-w-ac px-6 py-[72px] sm:py-[108px]">
    {section.heading && <h2 class="reveal ac-heading max-w-4xl text-ink">{section.heading}</h2>}
    <div class="mt-12 grid border-t border-line/50 sm:grid-cols-2">
      {items.map((item) => (
        <div class="reveal border-b border-line/50 py-9 pr-8 sm:[&:nth-child(odd)]:border-r sm:[&:nth-child(odd)]:border-line/50 sm:[&:nth-child(odd)]:pr-12 sm:[&:nth-child(even)]:pl-12">
          <h3 class="font-heading text-xl font-normal text-ink">{item.title}</h3>
          <p class="mt-3 text-ink/75">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
