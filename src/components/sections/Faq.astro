---
// FAQ section: accessible native <details> disclosures + FAQPage JSON-LD.
// Styled minimal with hairline rules — no cards. Renders only from supplied
// items — no invented questions.
const { section } = Astro.props;
const items = (section.items ?? []).filter((it) => it && it.q && it.a);
const faqSchema = items.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: items.map((it) => ({
        '@type': 'Question',
        name: it.q,
        acceptedAnswer: { '@type': 'Answer', text: it.a },
      })),
    }
  : null;
---
<section class="">
  <div class="mx-auto max-w-3xl px-6 py-[72px] sm:py-[108px]">
    {section.heading && (
      <h2 class="reveal ac-heading text-ink">{section.heading}</h2>
    )}
    <div class="mt-12 border-t border-line/50">
      {items.map((it) => (
        <details class="group border-b border-line/50">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-6 font-heading text-lg font-normal text-ink [&::-webkit-details-marker]:hidden">
            <span>{it.q}</span>
            <span aria-hidden="true" class="shrink-0 text-accent transition-transform duration-200 group-open:rotate-45">+</span>
          </summary>
          <p class="pb-6 pr-8 text-ink/75">{it.a}</p>
        </details>
      ))}
    </div>
  </div>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</section>
