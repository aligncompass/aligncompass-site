---
import CloudinaryImage from '../CloudinaryImage.astro';
const { section, content } = Astro.props;
const { cloudinary, cta } = content;
const img = section.image;
---
<section class="relative overflow-hidden bg-bg-muted">
  <div class="mx-auto grid max-w-ac items-center gap-10 px-6 py-16 sm:py-24 lg:grid-cols-2">
    <div class="reveal">
      {section.eyebrow && (
        <p class="mb-4 text-sm font-medium uppercase tracking-wide text-accent">{section.eyebrow}</p>
      )}
      <h1 class="font-heading text-4xl font-semibold leading-tight text-ink sm:text-5xl">{section.headline}</h1>
      {section.subhead && <p class="mt-5 max-w-xl text-lg text-muted">{section.subhead}</p>}
      <div class="mt-8 flex flex-wrap items-center gap-4">
        {cta?.primary && (
          <a href={cta.primary.href} class="inline-flex items-center rounded-ac bg-accent px-6 py-3 font-medium text-accent-contrast shadow-ac transition-transform hover:-translate-y-0.5">{cta.primary.label}</a>
        )}
        {cta?.transitional && (
          <a href={cta.transitional.href} class="inline-flex items-center font-medium text-ink underline-offset-4 hover:underline">{cta.transitional.label} →</a>
        )}
      </div>
    </div>
    {img && (
      <div class="reveal">
        <CloudinaryImage
          cloudName={cloudinary.cloudName}
          publicId={img.publicId}
          alt={img.alt}
          loading="eager"
          fetchpriority="high"
          sizes="(min-width: 1024px) 40rem, 100vw"
          class="aspect-[4/3] w-full rounded-ac object-cover shadow-ac"
        />
      </div>
    )}
  </div>
</section>
