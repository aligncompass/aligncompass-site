---
import { cldUrl, cldVideoUrl } from '../../lib/cloudinary.js';
const { section, content } = Astro.props;
const { cloudinary, cta } = content;
const img = section.image;
const cn = cloudinary.cloudName;

// The compass motif: a looping video (compass-glass-loop) with the still
// (compass-glass-still) as poster + reduced-motion fallback. Both are
// pure-black-based glass-compass renders that we screen-blend + radial-mask into
// the near-black canvas so they float with depth and have no hard rectangle
// edges. The compass sits large and centered, overlapping/behind the headline,
// with a soft glow halo. The video publicId is supplied in content.
const stillId = img?.publicId;
const videoId = img?.videoPublicId;
const stillUrl = stillId ? cldUrl(cn, stillId, { width: 1280, transforms: 'f_auto,q_auto' }) : '';
const videoUrl = videoId ? cldVideoUrl(cn, videoId, { width: 1280 }) : '';
const hasMotif = Boolean(stillId);
---
<section class="relative overflow-hidden bg-bg">
  {/* Ambient bloom over the near-black canvas (warm + cool corner leaks + vignette). */}
  <div class="ac-atmos ac-atmos--hero" aria-hidden="true"></div>
  {hasMotif && (
    <div class="pointer-events-none absolute inset-0 hidden lg:block" aria-hidden="true">
      {/* Large, centred glass compass that overlaps/sits behind the headline. */}
      <div class="ac-compass ac-compass--float absolute left-1/2 top-1/2 h-[150%] w-[80%] -translate-x-1/2 -translate-y-1/2">
        <div class="ac-compass-halo"></div>
        {videoUrl ? (
          <video
            class="h-full w-full object-contain ac-reduced-hide"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={stillUrl}
          >
            <source src={videoUrl} type="video/mp4" />
          </video>
        ) : (
          <img
            src={stillUrl}
            alt=""
            class="h-full w-full object-contain ac-compass--spin"
            loading="eager"
            decoding="async"
          />
        )}
        {/* Reduced-motion / no-video fallback still */}
        {videoUrl && (
          <img
            src={stillUrl}
            alt=""
            class="ac-reduced-show absolute inset-0 h-full w-full object-contain"
            loading="eager"
            decoding="async"
          />
        )}
      </div>
      {/* Soft near-black bloom under the text column so Bone White type keeps AA contrast. */}
      <div class="ac-hero-scrim absolute inset-0"></div>
    </div>
  )}
  <div class="relative mx-auto max-w-ac px-6 py-[72px] sm:py-[108px]">
    <div class="reveal max-w-4xl">
      {section.eyebrow && (
        <p class="mb-6 ac-label text-ink/70">{section.eyebrow}</p>
      )}
      <h1 class="ac-display text-ink">{section.headline}</h1>
      {section.subhead && <p class="ac-subhead mt-8 max-w-2xl text-ink/80">{section.subhead}</p>}
      <div class="mt-10 flex flex-wrap items-center gap-5">
        {cta?.primary && (
          <a href={cta.primary.href} class="ac-ghost">{cta.primary.label}</a>
        )}
        {cta?.transitional && (
          <a href={cta.transitional.href} class="ac-link">{cta.transitional.label} →</a>
        )}
      </div>
    </div>
    {hasMotif && (
      <div class="reveal relative mt-12 lg:hidden">
        <div class="ac-compass relative mx-auto aspect-[16/10] w-full max-w-md overflow-hidden">
          <div class="ac-compass-halo"></div>
          <img
            src={stillUrl}
            alt={img.alt}
            class="ac-compass--spin h-full w-full object-contain"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    )}
  </div>
</section>
