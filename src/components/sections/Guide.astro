---
const { section } = Astro.props;
const authority = section.authority ?? [];
// NOTE: the per-section compass image has been removed. A single roaming compass
// (Layout.astro) now serves the whole page; Guide sections are clean type on the
// near-black canvas, with the section content spanning the full width.
---
<section class="relative overflow-hidden">
  {/* Subtle ambient bloom + vignette over the near-black canvas. */}
  <div class="ac-atmos" aria-hidden="true"></div>
  <div class="relative mx-auto grid max-w-ac items-center gap-12 px-6 py-[72px] sm:py-[108px]">
    <div class="reveal">
      {section.heading && <h2 class="ac-heading text-ink">{section.heading}</h2>}
      {section.empathy && <p class="ac-subhead mt-6 text-ink/80">{section.empathy}</p>}
      {authority.length > 0 && (
        <ul class="mt-10 border-t border-line/50">
          {authority.map((a) => (
            <li class="flex gap-4 border-b border-line/50 py-4 text-ink/80">
              <span aria-hidden="true" class="ac-label shrink-0 text-accent">—</span>
              <span>{a}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>
