---
import CloudinaryImage from '../CloudinaryImage.astro';
const { section, content } = Astro.props;
const { cloudinary } = content;
const img = section.image;
const authority = section.authority ?? [];
---
<section class="bg-bg">
  <div class="mx-auto grid max-w-ac items-center gap-12 px-6 py-[72px] sm:py-[108px] lg:grid-cols-2">
    {img && (
      <div class="reveal order-last lg:order-first">
        <CloudinaryImage
          cloudName={cloudinary.cloudName}
          publicId={img.publicId}
          alt={img.alt}
          sizes="(min-width: 1024px) 36rem, 100vw"
          transforms="f_auto,q_auto,c_fill,g_auto"
          class="ac-prism aspect-square w-full object-cover opacity-80"
        />
      </div>
    )}
    <div class={`reveal ${img ? '' : 'lg:col-span-2'}`}>
      {section.heading && <h2 class="ac-heading text-ink">{section.heading}</h2>}
      {section.empathy && <p class="ac-subhead mt-6 text-ink/80">{section.empathy}</p>}
      {authority.length > 0 && (
        <ul class="mt-10 border-t border-line/50">
          {authority.map((a) => (
            <li class="flex gap-4 border-b border-line/50 py-4 text-ink/80">
              <span aria-hidden="true" class="ac-label shrink-0 text-accent">—</span>
              <span>{a}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>
