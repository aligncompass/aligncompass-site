---
const { section } = Astro.props;
const includes = section.includes ?? [];
---
<section class="">
  <div class="mx-auto max-w-ac px-6 py-[72px] sm:py-[108px]">
    {section.heading && <h2 class="reveal ac-heading max-w-4xl text-ink">{section.heading}</h2>}
    {section.price && <p class="reveal mt-6 font-heading text-3xl font-normal text-ink sm:text-4xl">{section.price}</p>}
    {includes.length > 0 && (
      <ul class="reveal mt-12 border-t border-line/50">
        {includes.map((it) => (
          <li class="flex gap-4 border-b border-line/50 py-5 text-ink/80">
            <span aria-hidden="true" class="ac-label shrink-0 text-accent">✓</span>
            <span class="ac-subhead">{it}</span>
          </li>
        ))}
      </ul>
    )}
    {section.cta && (
      <a href={section.cta.href} class="ac-ghost mt-12">{section.cta.label}</a>
    )}
  </div>
</section>
