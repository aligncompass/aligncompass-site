---
const { section } = Astro.props;
const testimonials = section.testimonials ?? [];
---
<section class="">
  <div class="mx-auto max-w-ac px-6 py-[72px] sm:py-[108px]">
    {section.heading && <h2 class="reveal ac-heading max-w-4xl text-ink">{section.heading}</h2>}
    <div class="mt-12 grid border-t border-line/50 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <figure class="reveal flex flex-col border-b border-line/50 py-9 pr-8">
          <blockquote class="ac-subhead text-ink">“{t.quote}”</blockquote>
          <figcaption class="mt-5 ac-label text-ink/60">
            <span class="text-ink">{t.name}</span>{t.detail && <span> · {t.detail}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
