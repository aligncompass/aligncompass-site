---
// Pricing tiers as clean type columns separated by hairline rules — no cards,
// no shadows. A featured tier is marked with a small accent label, not a panel.
// Renders only the prices/fields supplied — never invents numbers.
const { section } = Astro.props;
const tiers = section.tiers ?? [];
const cols = tiers.length === 2 ? 'lg:grid-cols-2' : 'lg:grid-cols-3';
---
<section class="bg-bg">
  <div class="mx-auto max-w-ac px-6 py-[72px] sm:py-[108px]">
    {section.heading && (
      <h2 class="reveal ac-heading max-w-4xl text-ink">{section.heading}</h2>
    )}
    {section.subhead && <p class="reveal ac-subhead mt-5 max-w-2xl text-ink/80">{section.subhead}</p>}
    <div class={`mt-12 grid border-t border-line/50 sm:grid-cols-2 ${cols}`}>
      {tiers.map((t) => (
        <div class="reveal flex flex-col border-b border-line/50 py-9 pr-8 lg:border-r lg:border-line/50 lg:pl-8 lg:pr-12 lg:first:pl-0">
          {t.featured && (
            <span class="mb-4 ac-label text-accent">Most popular</span>
          )}
          <h3 class="font-heading text-xl font-normal text-ink">{t.name}</h3>
          {t.price && (
            <p class="mt-4 font-heading text-3xl font-normal text-ink">
              {t.price}
              {t.cadence && <span class="ml-1 align-middle text-sm font-normal text-ink/60">{t.cadence}</span>}
            </p>
          )}
          {t.description && <p class="mt-3 text-ink/75">{t.description}</p>}
          {(t.includes ?? []).length > 0 && (
            <ul class="mt-7 space-y-3">
              {t.includes.map((it) => (
                <li class="flex gap-3 text-ink/80"><span aria-hidden="true" class="text-accent">✓</span><span>{it}</span></li>
              ))}
            </ul>
          )}
          {t.cta && (
            <a href={t.cta.href} class={`ac-ghost mt-8 self-start ${t.featured ? '' : 'ac-ghost--accent'}`}>{t.cta.label}</a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
