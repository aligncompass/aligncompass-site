---
const { section } = Astro.props;
const items = section.items ?? [];
---
<section class="">
  <div class="mx-auto max-w-ac px-6 py-[72px] sm:py-[108px]">
    {section.heading && <h2 class="reveal ac-heading max-w-4xl text-ink">{section.heading}</h2>}
    <ul class="mt-12 border-t border-line/50">
      {items.map((item) => (
        <li class="reveal flex gap-5 border-b border-line/50 py-7 text-ink/80">
          <span aria-hidden="true" class="ac-label shrink-0 text-accent">✕</span>
          <span class="ac-subhead">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
