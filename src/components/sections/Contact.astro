---
const { section, content } = Astro.props;
const { nap } = content;
const form = section.form ?? {};
const fields = form.fields ?? ['name', 'email', 'message'];
// Static site: post to a real form endpoint if one is configured, otherwise
// fall back to a mailto so the button always does something real. A booking
// widget, when present, is a link/tel target — never a fake backend.
const action = form.endpoint || (nap.email ? `mailto:${nap.email}` : undefined);
const labels = {
  name: 'Your name',
  email: 'Email',
  phone: 'Phone',
  business: 'Business name',
  trade: 'Trade / industry',
  calls: 'Calls per week (approx)',
  customers: 'Roughly how many past customers?',
  message: 'How can we help?',
};
const requiredFields = ['name', 'email', 'message'];
const fieldClass = 'w-full border-0 border-b border-line/60 bg-transparent px-0 py-3 text-ink placeholder:text-ink/50 focus:border-ink focus:outline-none';
---
<section id={section.id} class="bg-bg">
  <div class="mx-auto grid max-w-ac gap-12 px-6 py-[72px] sm:py-[108px] lg:grid-cols-2">
    <div class="reveal">
      {section.heading && <h2 class="ac-heading text-ink">{section.heading}</h2>}
      {section.body && <p class="ac-subhead mt-6 text-ink/80">{section.body}</p>}
      {section.showNap && (
        <ul class="mt-10 space-y-3 text-ink/80">
          {nap.phone && <li><a class="text-ink hover:text-accent" href={`tel:${nap.phone}`}>{nap.phone}</a></li>}
          {nap.email && <li><a class="text-ink hover:text-accent" href={`mailto:${nap.email}`}>{nap.email}</a></li>}
          {(nap.streetAddress || nap.addressLocality) && (
            <li>{[nap.streetAddress, nap.addressLocality, nap.addressRegion, nap.postalCode].filter(Boolean).join(', ')}</li>
          )}
          {nap.hours && <li>{nap.hours}</li>}
        </ul>
      )}
    </div>
    {form.enabled && action && (
      <form class="reveal space-y-6" action={action} method={form.endpoint ? 'POST' : undefined}>
        {fields.map((field) => (
          field === 'message' ? (
            <textarea name="message" rows="4" required placeholder={labels.message} class={fieldClass}></textarea>
          ) : (
            <input
              name={field}
              type={field === 'email' ? 'email' : field === 'phone' ? 'tel' : 'text'}
              required={requiredFields.includes(field)}
              placeholder={labels[field] || field}
              class={fieldClass}
            />
          )
        ))}
        <button type="submit" class="ac-ghost">Send</button>
      </form>
    )}
  </div>
</section>
