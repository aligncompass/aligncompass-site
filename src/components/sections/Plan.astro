---
const { section } = Astro.props;
const steps = section.steps ?? [];
---
<section id={section.id} class="">
  <div class="mx-auto max-w-ac px-6 py-[72px] sm:py-[108px]">
    {section.heading && <h2 class="reveal ac-heading max-w-4xl text-ink">{section.heading}</h2>}
    <ol class="mt-12 border-t border-line/50">
      {steps.map((step, i) => (
        <li class="reveal grid gap-4 border-b border-line/50 py-9 sm:grid-cols-[auto_1fr] sm:gap-10">
          <span class="font-heading text-3xl font-normal text-accent">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3 class="font-heading text-xl font-normal text-ink">{step.title}</h3>
            <p class="mt-3 max-w-2xl text-ink/75">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
