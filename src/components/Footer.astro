---
const { content } = Astro.props;
const { meta, nap, nav = [], footer = {} } = content;
const year = new Date().getFullYear();
---
<footer class="border-t border-line/60">
  <div class="mx-auto grid max-w-ac gap-10 px-6 py-20 sm:grid-cols-2 lg:grid-cols-4">
    <div class="sm:col-span-2 lg:col-span-1">
      <p class="font-heading text-lg font-normal text-ink">{meta.businessName}</p>
      {footer.blurb && <p class="mt-3 text-ink/70">{footer.blurb}</p>}
    </div>
    <nav aria-label="Footer">
      <p class="ac-label text-ink/60">Explore</p>
      <ul class="mt-4 space-y-3">
        {nav.map((item) => (
          <li><a href={item.href} class="text-ink/70 hover:text-ink">{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <div>
      <p class="ac-label text-ink/60">Contact</p>
      <ul class="mt-4 space-y-3 text-ink/70">
        {nap.phone && <li><a href={`tel:${nap.phone}`} class="hover:text-ink">{nap.phone}</a></li>}
        {nap.email && <li><a href={`mailto:${nap.email}`} class="hover:text-ink">{nap.email}</a></li>}
        {(nap.streetAddress || nap.addressLocality) && (
          <li>{[nap.streetAddress, nap.addressLocality, nap.addressRegion, nap.postalCode].filter(Boolean).join(', ')}</li>
        )}
      </ul>
    </div>
    <div>
      <p class="ac-label text-ink/60">Hours</p>
      <ul class="mt-4 space-y-3 text-ink/70">
        {footer.showHours && nap.hours && <li>{nap.hours}</li>}
        {nap.serviceArea && <li>{nap.serviceArea}</li>}
      </ul>
    </div>
  </div>
  <div class="border-t border-line/60">
    <p class="mx-auto max-w-ac px-6 py-6 ac-label text-ink/50">
      © {year} {nap.name || meta.businessName}. All rights reserved.
    </p>
  </div>
</footer>
