---
// ── GLOBAL SCROLL-SCRUBBED CINEMATIC BACKDROP ("scrollytelling") ──────────────
// Apple-product-page style, but spread across the WHOLE home page: the 4-clip
// Higgsfield compass→landscape storyboard is a position:FIXED, full-viewport
// layer that sits BEHIND every section (low z-index; nav/main/footer above it).
// A single requestAnimationFrame scroll handler computes TOTAL document scroll
// progress 0→1 and drives the active clip's currentTime DIRECTLY — strictly
// proportional, video kept paused (only seeked), no autoplay / no loop, freezes
// the instant scrolling stops.
//
// THEMATIC MAPPING (band boundaries derived at runtime from the real section
// scroll offsets via data-seq-anchor, NOT even quarters):
//   clip 1  seq-1-wordmark : hero band — wordmark on navy → compass grows/spins.
//   clip 2  seq-2-tilt     : hero→stakes handoff — the compass tilts / lays down.
//   clip 3  seq-3-barren   : the STAKES section ("you can't be two places at
//                            once — it's costing you") — dissolve into the
//                            barren badlands; the barren frame sits behind that
//                            section's text.
//   clip 4  seq-4-green    : the VALUE section ("Everything you can't get to,
//                            handled") — bloom into the lush green valley.
//   hold    seq-4-green@end : remaining sections (plan / proof / pricing / FAQ /
//                            contact + the folded GTM closing) hold the green
//                            END frame, so the resolved state carries to the CTA.
//
// Overlays (hero band) are real, crisp HTML (NOT baked into the video): an
// eyebrow + a guarantee line in the real brand voice, fading out as the hero
// scrolls away. A phase-tuned scrim keeps bone-white #fffdf9 type AA on every
// frame (stronger over the bright green and the barren badlands).
import { cldVideoUrl } from '../lib/cloudinary.js';

const { content } = Astro.props;
const { design, cloudinary } = content;
const cloud = cloudinary.cloudName;

// The 4-clip storyboard, from content.json design.scrollSeq (single source of truth).
const seq = Array.isArray(design.scrollSeq) ? design.scrollSeq : [];

// Build, per clip, the streamed mp4 src + a Cloudinary first-frame poster (so_0 →
// jpg) so each band shows something before/while the video buffers — and the
// hero band shows the wordmark poster even if the seq-1 video 404s (still
// uploading). Phase metadata tags which clips are the "metal-on-navy" compass
// phases (so we keep a navy base behind them) vs. the landscape phases (which
// bring their own colour).
const PHASE = ['compass', 'compass', 'landscape', 'landscape'];
const clips = seq.map((id, i) => ({
  id,
  // h264 mp4 from Cloudinary; modest width keeps the file scrub-friendly.
  src: cldVideoUrl(cloud, id, { width: 1280, transforms: 'f_mp4,q_auto', ext: 'mp4' }),
  // First frame of the VIDEO rendered as a still jpg (image/upload on a video
  // public id with so_0 gives the frame at t=0).
  poster: `https://res.cloudinary.com/${cloud}/video/upload/so_0,f_jpg,q_auto,w_1280/${id}.jpg`,
  // A LAST-frame still (so_e... isn't available, so we use a large so_ value;
  // Cloudinary clamps to the final frame) — used as the parked "green end" base.
  endPoster: `https://res.cloudinary.com/${cloud}/video/upload/so_999,f_jpg,q_auto,w_1280/${id}.jpg`,
  band: i,
  phase: PHASE[i] || 'landscape',
}));

// Posters for the static (reduced-motion / no-JS) fallback hero and the parked
// green-end hold. Both come from Cloudinary stills.
const wordmarkPoster = clips[0]?.poster || '';
const greenEndPoster = clips[3]?.endPoster || clips[3]?.poster || '';

// ── Overlay copy ──────────────────────────────────────────────────────────────
// Guarantee line in the REAL brand voice. The actual offer is "free website,
// pay when it works — you don't pay until it covers itself (~60 days); if it
// doesn't pay for itself you don't pay." So the guarantee is accurate as: we
// catch the work you can't get to, and you don't pay until it pays for itself.
const eyebrow = 'aligncompass';
const guaranteeLine = "We catch the work you can't get to — and you don't pay until it pays for itself.";
const guaranteeSub = 'Free website. Missed calls texted back, past customers re-booked, reviews handled. Pay only when it works.';
---
{seq.length > 0 && (
  <div
    id="ac-seq"
    class="ac-seq"
    data-seq-count={seq.length}
    data-green-poster={greenEndPoster}
    aria-hidden="true"
  >
    {/* Fixed, full-viewport backdrop holding the 4 stacked clips. NOT autoplay /
        NOT loop — the scroll script drives currentTime. Each has a Cloudinary
        first-frame poster so the band is never blank (incl. the hero band if
        seq-1 is still uploading / 404s). */}
    <div class="ac-seq-stack">
      {clips.map((clip) => (
        <video
          class="ac-seq-video"
          data-band={clip.band}
          data-phase={clip.phase}
          data-src={clip.src}
          poster={clip.poster}
          preload="auto"
          muted
          playsinline
          disablepictureinpicture
          disableremoteplayback
        >
          <source src={clip.src} type="video/mp4" />
        </video>
      ))}
    </div>

    {/* Phase-tuned legibility scrim. The engine sets its opacity/strength per
        phase (stronger over the bright green valley and the barren badlands) so
        bone-white type stays AA over every frame. */}
    <div id="ac-seq-scrim" class="ac-seq-scrim"></div>

    {/* Reduced-motion / no-JS static fallback: wordmark poster (a calm compass
        hero). Shown only when .ac-seq-static is set (reduced-motion) — see CSS. */}
    <div class="ac-seq-static-fallback">
      <img
        class="ac-seq-static-img"
        src={wordmarkPoster}
        alt=""
        loading="eager"
        decoding="async"
        onerror={greenEndPoster ? `this.onerror=null;this.src='${greenEndPoster}'` : 'this.style.display="none"'}
      />
    </div>
  </div>
)}

{seq.length > 0 && (
  <>
    {/* Hero-band HTML overlay: crisp HTML text (eyebrow + guarantee), fixed over
        the backdrop, fading out as the hero scrolls away. Real content, not
        baked into the video. Lives OUTSIDE the aria-hidden backdrop so its copy
        stays in the accessibility tree. pointer-events:none so it never blocks
        the nav / content beneath. */}
    <div id="ac-seq-overlay" class="ac-seq-overlay">
      <div class="ac-seq-overlay-inner">
        <p class="ac-label ac-seq-eyebrow">{eyebrow}</p>
        <p class="ac-seq-guarantee">{guaranteeLine}</p>
        <p class="ac-seq-guarantee-sub">{guaranteeSub}</p>
      </div>
    </div>
    {/* Scroll cue — fades after the first scroll. */}
    <div id="ac-seq-cue" class="ac-seq-cue" aria-hidden="true">
      <span class="ac-seq-cue-text">Scroll</span>
      <span class="ac-seq-cue-arrow"></span>
    </div>
  </>
)}

<script>
  // ── GLOBAL SCROLL-SCRUB ENGINE ───────────────────────────────────────────────
  // Maps TOTAL document scroll progress to a frame in the 4-clip storyboard,
  // with the band boundaries derived from the real scroll offsets of the tagged
  // sections (data-seq-anchor="hero|stakes|value") so the barren frame aligns
  // with the stakes section and the green valley with the value section — while
  // the whole scroll stays animated (spread across the page, not crammed at the
  // top).
  //
  // Boundaries (document scrollY, in px), built once per layout and on resize:
  //   B0 = 0                              (top — clip 1 starts: wordmark)
  //   Bs = top of the STAKES section      (clip 3 barren begins here)
  //   Bv = top of the VALUE section       (clip 4 green begins here)
  //   Be = a little past Bv               (green fully bloomed; then HOLD)
  // Between B0 and Bs we run clip 1 then clip 2 (the compass tilt handoff),
  // splitting that span so clip 1 fills the hero and clip 2 the hero→stakes gap.
  // From Be to the end of the document we PARK clip 4 at its last frame.
  //
  //   currentTime = localProgress × clip.duration   (video kept PAUSED; only
  //   seeked; no easing toward target → freezes the instant scrolling stops).
  // Only the active clip is seeked. Opacity is the only animated property
  // (will-change:opacity). Everything runs in one rAF scheduled on scroll.
  //
  // Reduced motion: no scrubbing — a static compass poster backdrop is shown.
  // Mobile uses the SAME strict scrub (no autoplay-through branch — that reads
  // as "the video plays itself"; per the cinematic-scroll-hero skill).
  (function () {
    const root = document.getElementById('ac-seq');
    if (!root) return;
    const videos = Array.prototype.slice.call(root.querySelectorAll('.ac-seq-video'));
    if (!videos.length) return;

    const scrim = document.getElementById('ac-seq-scrim');
    const overlay = document.getElementById('ac-seq-overlay');
    const cue = document.getElementById('ac-seq-cue');
    const tint = document.getElementById('ac-tint');
    const N = videos.length;

    const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    const mqSmall = window.matchMedia('(max-width: 767px)');

    const clamp = (v, lo, hi) => Math.min(hi, Math.max(lo, v));
    const lerp = (a, b, t) => a + (b - a) * t;
    const smooth = (t) => t * t * (3 - 2 * t);

    // Per-video cached duration (filled on loadedmetadata).
    const meta = videos.map(() => ({ duration: NaN }));
    videos.forEach((v, i) => {
      const onMeta = () => {
        if (v.duration && isFinite(v.duration)) meta[i].duration = v.duration;
      };
      if (v.readyState >= 1) onMeta();
      v.addEventListener('loadedmetadata', onMeta);
      // If a clip 404s (e.g. seq-1 still uploading), keep its poster — the band
      // is never blank — and just skip seeking it (duration stays NaN).
      v.addEventListener('error', () => { meta[i].duration = NaN; }, true);
      try { v.load(); } catch (e) {}
    });

    // ── Band boundaries from real section offsets ───────────────────────────
    // Returns absolute document-scroll positions for the phase boundaries.
    // Falls back to even thirds of the document if anchors are missing.
    function docScrollMax() {
      return (document.documentElement.scrollHeight - window.innerHeight) || 1;
    }
    function topOf(sel) {
      const el = document.querySelector(sel);
      if (!el) return null;
      const r = el.getBoundingClientRect();
      return r.top + window.scrollY;
    }
    // ── MORPH-ZONE + HOLD MODEL ─────────────────────────────────────────────
    // Each themed landscape must be FULLY RESOLVED by the TOP of its section and
    // then HOLD (frozen at that clip's end frame) across the whole section body.
    // The morph happens only in a short zone right BEFORE the section top.
    //
    //   stakes(bs):  clip 3 BARREN scrubs 0→1 across [bs - mLen, bs]; resolved by
    //                bs; then HOLDS at the barren end frame across [bs, mv].
    //   value(bv):   clip 4 GREEN  scrubs 0→1 across [mv = bv - mLen, bv]; resolved
    //                by bv; then HOLDS at the green end frame from bv to the end.
    //   hero [0, bs - mLen]: clip 1 (wordmark→compass) then clip 2 (tilt) play and
    //                resolve, so the compass has tilted by the time the barren
    //                morph zone begins.
    // currentTime stays a pure function of scrollY (the holds are just flat
    // segments of that function) → video paused; freezes the instant idle.
    let B = { hero: 0, mStakes: 0, stakes: 0, mValue: 0, value: 0, max: 1 };
    function computeBounds() {
      const max = docScrollMax();
      const vh = window.innerHeight;
      // Real section tops (data-seq-anchor is on the wrapper div in index.astro).
      let bs = topOf('[data-seq-anchor="stakes"]');
      let bv = topOf('[data-seq-anchor="value"]');
      // Defensive fallbacks so the scrub always runs even if anchors move.
      if (bs == null) bs = max * 0.4;
      if (bv == null) bv = max * 0.68;
      // Clamp into sane, ordered ranges (value must sit below stakes).
      bs = clamp(bs, vh * 0.5, max);
      bv = clamp(bv, bs + vh * 0.4, max);
      // Morph-zone length: a short band ending exactly at each section top, in
      // which the active clip scrubs start→end. ~80vh, but never eating more
      // than ~45% of the preceding span so a hold always remains visible.
      const heroSpan = bs;                 // [0 .. stakes-top]
      const stakesSpan = bv - bs;          // [stakes-top .. value-top]
      const mLenStakes = clamp(vh * 0.8, vh * 0.3, heroSpan * 0.45);
      const mLenValue = clamp(vh * 0.8, vh * 0.3, stakesSpan * 0.55);
      const mStakes = clamp(bs - mLenStakes, 0, bs - 1);   // barren morph begins
      const mValue = clamp(bv - mLenValue, bs, bv - 1);    // green morph begins
      B = { hero: 0, mStakes: mStakes, stakes: bs, mValue: mValue, value: bv, max: max };
    }

    let activeBand = -1;
    let cueHidden = false;
    let ticking = false;
    let reduced = mqReduce.matches;

    function showBand(k) {
      if (k === activeBand) return;
      activeBand = k;
      videos.forEach((v, i) => { v.style.opacity = i === k ? '1' : '0'; });
    }

    // Phase-tuned scrim strength + tint opacity, by band/phase. Now that the
    // barren and green END frames HOLD (parked) across whole sections — their
    // brightest frames sitting still behind bone-white type — the held states
    // get a stronger scrim so #fffdf9 stays AA across the entire hold, not just
    // mid-morph. The morph zones ramp toward the held strength.
    function applyPhase(band, parked) {
      if (!scrim) return;
      let strength;
      if (band <= 1) strength = 0.34;          // compass phases (navy base)
      else if (band === 2) strength = parked ? 0.68 : 0.6;  // barren: held end is brighter
      else strength = parked ? 0.74 : 0.64;    // green valley (brightest); held end strongest
      scrim.style.setProperty('--seq-scrim', String(strength));
      // Navy base (#ac-tint) is for the metal-on-navy compass phases only; it
      // fades out as we cross into the landscape phases so the green/barren
      // bring their own colour.
      if (tint) {
        const tintOpacity = band <= 1 ? 1 : (band === 2 ? 0.35 : 0);
        tint.style.opacity = String(tintOpacity);
      }
    }

    function seekActive(band, q) {
      const d = meta[band].duration;
      if (!(d && isFinite(d))) return;
      // The frame is a DIRECT function of scroll position — no easing, no
      // auto-advance — so playback freezes the instant scrolling stops. The
      // video is kept paused; we only seek. Clamp off the exact end (some
      // decoders blank on the final frame).
      const target = clamp(q * d, 0, d - 0.05);
      const v = videos[band];
      try {
        if (!v.paused) v.pause();
        if (Math.abs((v.currentTime || 0) - target) > 0.01) v.currentTime = target;
      } catch (e) {}
    }

    function render() {
      ticking = false;
      const y = window.scrollY || window.pageYOffset || 0;

      // Five segments along scrollY, mapping to morph zones + holds:
      //   [0 .. mStakes)        HERO: clip 0 (wordmark→compass) then clip 1 (tilt)
      //   [mStakes .. stakes)   MORPH → barren: clip 2 scrubs 0→1
      //   [stakes .. mValue)    HOLD barren: clip 2 pinned at end frame
      //   [mValue .. value)     MORPH → green: clip 3 scrubs 0→1
      //   [value .. end]        HOLD green: clip 3 pinned at end frame
      let band, q, parked = false;
      if (y < B.mStakes) {
        // HERO: the compass phases play and resolve (tilted) before the barren
        // morph zone begins. Split clip 0 / clip 1 across the hero span.
        const span = B.mStakes - B.hero || 1;
        const p = clamp((y - B.hero) / span, 0, 1);
        if (p < 0.55) { band = 0; q = p / 0.55; }
        else { band = 1; q = (p - 0.55) / 0.45; }
      } else if (y < B.stakes) {
        // MORPH → BARREN: short zone just before the stakes top; clip 2 scrubs
        // start→end so the barren badlands is fully resolved AT stakes-top.
        band = 2;
        q = clamp((y - B.mStakes) / ((B.stakes - B.mStakes) || 1), 0, 1);
      } else if (y < B.mValue) {
        // HOLD BARREN: pin clip 2 at its end frame across the whole stakes body.
        band = 2;
        q = 1;
        parked = true;
      } else if (y < B.value) {
        // MORPH → GREEN: short zone just before the value top; clip 3 scrubs
        // start→end so the green valley is fully resolved AT value-top.
        band = 3;
        q = clamp((y - B.mValue) / ((B.value - B.mValue) || 1), 0, 1);
      } else {
        // HOLD GREEN: pin clip 3 at its end frame through value + every section
        // after it (plan/proof/pricing/FAQ/contact + folded GTM closing).
        band = 3;
        q = 1;
        parked = true;
      }

      showBand(band);
      applyPhase(band, parked);
      seekActive(band, q);

      // Hero overlay fades out as the hero scrolls away (gone by ~55% of the
      // hero span, i.e. while clip 0 is still the active compass phase).
      if (overlay) {
        const span = B.mStakes - B.hero || 1;
        const heroP = clamp((y - B.hero) / span, 0, 1);
        overlay.style.opacity = String(clamp(1 - heroP / 0.55, 0, 1));
      }

      if (!cueHidden && cue && y > 8) {
        cueHidden = true;
        cue.style.opacity = '0';
      }
    }

    function onScroll() {
      if (reduced) return;
      if (!ticking) { ticking = true; requestAnimationFrame(render); }
    }

    // ── REDUCED MOTION: static compass poster backdrop ──────────────────────
    function setupStatic() {
      root.classList.add('ac-seq-static');
      videos.forEach((v) => { try { v.pause(); } catch (e) {} v.style.opacity = '0'; });
      if (scrim) scrim.style.setProperty('--seq-scrim', '0.34');
      if (overlay) overlay.style.opacity = '1';
      if (cue) cue.style.display = 'none';
      if (tint) tint.style.opacity = '1';
    }

    function teardown() {
      window.removeEventListener('scroll', onScroll);
      root.classList.remove('ac-seq-static');
    }

    function setup() {
      teardown();
      reduced = mqReduce.matches;
      cueHidden = false;
      if (cue) { cue.style.display = ''; cue.style.opacity = ''; }
      if (reduced) { setupStatic(); return; }
      // Strict frame-scrub on ALL screen sizes (desktop AND mobile) — the frame
      // is tied to scroll position with no autoplay/loop, so the video never
      // advances on its own (it freezes when scrolling stops).
      computeBounds();
      window.addEventListener('scroll', onScroll, { passive: true });
      render();
    }

    setup();

    // Recompute boundaries on resize / late content/layout shifts.
    let rzT = null;
    window.addEventListener('resize', () => {
      clearTimeout(rzT);
      rzT = setTimeout(() => {
        if (reduced !== mqReduce.matches) { setup(); return; }
        if (!reduced) { computeBounds(); render(); }
      }, 150);
    }, { passive: true });
    // Fonts/images can shift section offsets after first paint — recompute once
    // settled and again on full load.
    window.addEventListener('load', () => { if (!reduced) { computeBounds(); render(); } });
    if (mqReduce.addEventListener) mqReduce.addEventListener('change', setup);
  })();
</script>
